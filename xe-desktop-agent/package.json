{
  "name": "xe-desktop-agent",
  "version": "1.0.0",
  "description": "XeWorkspace Desktop Monitoring Agent",
  "main": "out/main/index.js",
  "author": "XeWorkspace",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xenonlabs-ai/XeWorkSpace.git"
  },
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE= && electron-vite dev",
    "build": "electron-vite build",
    "start": "set ELECTRON_RUN_AS_NODE= && electron .",
    "preview": "set ELECTRON_RUN_AS_NODE= && electron-vite preview",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.xeworkspace.desktop-agent",
    "productName": "XeWorkspace Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
