# ============================================
# XeTask Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/xeworkspace"

# For local development, you can also use SQLite:
# DATABASE_URL="file:./prisma/dev.db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# ============================================
# Storage Configuration
# ============================================
# Storage provider: "local" or "s3"
STORAGE_PROVIDER="local"

# S3 Configuration (required if STORAGE_PROVIDER=s3)
AWS_S3_BUCKET="xeworkspace-media"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"

# Storage structure:
# Screenshots: s3://{bucket}/screenshots/{organizationId}/{filename}
# Videos: s3://{bucket}/videos/{organizationId}/{filename}

# ============================================
# Desktop Agent Configuration
# ============================================
# Agent authentication key (generate unique per deployment)
# AGENT_KEY_SECRET="your-agent-key-secret"
